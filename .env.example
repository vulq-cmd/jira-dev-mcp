# devflow-mcp — required environment variables.
# Copy to `.env` for local dev. NEVER commit `.env` (it is gitignored).

# --- Jira (Server/Data Center) — REQUIRED ---
JIRA_BASE_URL=https://jira.your-company.com
JIRA_PAT=your_personal_access_token

# --- Jira optional ---
# JIRA_VERIFY_SSL=true             # set false ONLY for trusted internal self-signed certs
# JIRA_HTTP_TIMEOUT=30
# JIRA_ACTIVE_STATUSES=To Do,Doing # my working set for jira_my_tasks (comma-separated)
# JIRA_ATTACHMENT_DIR=             # where downloaded attachments land (default: system temp)
# JIRA_EXTRA_FIELDS=               # custom field ids to also fetch (Story Points, Sprint,
                                   #   Acceptance Criteria) — find ids via jira_get_fields
                                   #   e.g. customfield_10026,customfield_10100

# --- GitLab (added in Phase 2) ---
# GITLAB_URL=https://gitlab.your-company.com
# GITLAB_TOKEN=glpat-xxxxxxxxxxxx   # scopes: read_api, read_repository
