# devflow-mcp — environment variables. Copy to `.env` (gitignored). NEVER commit `.env`.

# --- Jira (Server/Data Center) — REQUIRED ---
JIRA_BASE_URL=https://jira.your-company.com
JIRA_PAT=your_personal_access_token

# --- Jira optional ---
# JIRA_VERIFY_SSL=true              # false ONLY cho self-signed cert nội bộ
# JIRA_HTTP_TIMEOUT=30
# JIRA_ACTIVE_STATUSES=To Do,Doing  # working set cho jira_my_tasks
# JIRA_ASSIGNEES_FIELD=Assignees    # custom multi-user field; "" để tắt; hoặc cf[10xxx]
# JIRA_DESC_MAX=20000               # cắt description (0 = không giới hạn)
# JIRA_ATTACHMENT_DIR=              # nơi lưu attachment tải về (mặc định: temp)
# JIRA_EXTRA_FIELDS=                # custom field id cần lấy thêm (Story Points/Sprint/AC),
                                    #   vd customfield_10026,customfield_10100

# --- Jira WRITE (opt-in) — chỉ transition status, allowlist, confirm-gated ---
# JIRA_ENABLE_WRITE=false                          # true để bật jira_transition_issue
# JIRA_ALLOWED_TRANSITIONS=To Do,Doing,Waiting To Test

# --- GitLab (self-hosted) — optional ---
# GITLAB_URL=https://gitlab.your-company.com
# GITLAB_TOKEN=glpat-xxxxxxxxxxxx   # scopes: read_api, read_repository
# GITLAB_VERIFY_SSL=true

# --- Notion (optional) — đọc spec/docs đính trong ticket ---
# NOTION_TOKEN=secret_xxx           # internal integration + share page cho nó
# NOTION_VERSION=2022-06-28

# --- Figma (optional) — render frame design ra ảnh để xem ---
# FIGMA_TOKEN=figd_xxx              # Settings → Account → Personal access tokens
